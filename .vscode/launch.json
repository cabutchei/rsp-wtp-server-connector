// A launch configuration that compiles the extension and then opens it inside a new window
// Use IntelliSense to learn about possible attributes.
// Hover to view descriptions of existing attributes.
// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
{
	"version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}",
                "--extensionDevelopmentPath=${workspaceFolder}/../rsp-wtp-ui"
            ],
            "outFiles": [
                "${workspaceFolder}/out/**/*.js",
                "${workspaceFolder}/../rsp-wtp-ui/out/**/*.js"
            ],
            "preLaunchTask": "tsc: watch",
            "env": {
                "RSP_SERVER_LOCATION": "${workspaceFolder}/../rsp-wtp-server/distribution/distribution/target/products/com.github.cabutchei.rsp.server.product/macosx/cocoa/x86_64/rsp-wtp-server.app/Contents/Eclipse/plugins",
                "RSP_DEBUG_PORT": "5007",
                "JAVA_HOME": "${userHome}/.sdkman/candidates/java/17.0.12-oracle/",
                "EQUINOX_LAUNCH_SCRIPT": "{userHome}/Documents/vs_code/rsp-wtp-server/rsp-wtp-server/launch/run.sh"
            }
        },
        {
            "name": "Extension Tests Debug",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}",
                "--extensionTestsPath=${workspaceFolder}/out/test"
            ],
            "outFiles": [
                "${workspaceFolder}/out/test/**/*.js"
            ],
            // "preLaunchTask": "npm: watch",
            "env": {
                "VSCA_TEST_MODE": "debug"
            }
        },
        {
            "name": "Debug UI Tests",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/node_modules/.bin/extest",
            "args": [
                "setup-and-run",
                "'${workspaceFolder}/out/test/ui-test/allTestsSuite.js'",
                "--mocha_config",
                "${workspaceFolder}/test/ui-test/.mocharc-debug.js"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Extension Tests Coverage",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}",
                "--extensionTestsPath=${workspaceFolder}/out/test"
            ],
            "outFiles": [
                "${workspaceFolder}/out/test/**/*.js"
            ],
            "preLaunchTask": "npm: watch",
            "env": {
                "VSCA_TEST_MODE": "coverage"
            }
        }
    ]
}
